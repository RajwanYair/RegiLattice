<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Run the 3 test assemblies in parallel (one per project) -->
    <MaxCpuCount>3</MaxCpuCount>
    <!-- 300 s total session hard limit (1370+ tests need headroom) -->
    <TestSessionTimeout>300000</TestSessionTimeout>
    <!-- 30 s per individual test — generous for slow CI systems -->
    <TestCaseTimeout>30000</TestCaseTimeout>
  </RunConfiguration>
</RunSettings>
