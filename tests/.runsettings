<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Run the 3 test assemblies serially to prevent shared-file race conditions
         (ComplianceHistory tests in Core.Tests and GUI.Tests both use the same
         compliance-history.json file; parallel execution causes non-deterministic
         failures in AddEntry_ExceedsMaxEntries_TrimsOldestEntries). -->
    <MaxCpuCount>1</MaxCpuCount>
    <!-- 2000 s total session hard limit per assembly.
         CLI tests were hanging indefinitely on Intel/Intune machines due to:
           1. PackManager static HttpClient eager-calling WebRequest.GetSystemWebProxy() (WPAD hang)
           2. CorporateGuard.Status() hitting slow registry filter callbacks from Intune/SCCM
         Both root causes are now fixed. This 2000 s limit is a last-resort safety net.
         The Blame data collector (below) kills a single stuck test after 30 s — more reliable
         for per-test hangs than TestCaseTimeout which is MSTest-only. -->
    <TestSessionTimeout>2000000</TestSessionTimeout>
    <!-- 20 s per individual test — only honoured by MSTest adapter; kept as belt-and-suspenders -->
    <TestCaseTimeout>20000</TestCaseTimeout>
    <!--
      IMPORTANT: Always run per-project, NOT solution-level:
        dotnet test tests/RegiLattice.Core.Tests/...
        dotnet test tests/RegiLattice.CLI.Tests/...
        dotnet test tests/RegiLattice.GUI.Tests/...
      Running 'dotnet test RegiLattice.sln' stalls vstest discovery on non-test projects.
      The 'test: All' VS Code task and CI workflows both use per-project runs.
    -->
  </RunConfiguration>

  <!-- Blame data collector: terminates a hung test host.
       In .NET SDK 10.0.201+, the HangTimeout attribute on CollectDumpOnTestSessionHang
       is no longer a supported configuration key (produces a non-fatal warning if used).
       The primary hang-protection mechanism is TestSessionTimeout above (2000 s).
       DumpType="None" avoids writing memory dumps on OneDrive-hosted workspaces. -->
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="blame" enabled="True">
        <Configuration>
          <CollectAlways>false</CollectAlways>
          <CollectDumpOnTestSessionHang DumpType="None" />
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
