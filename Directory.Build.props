<Project>
  <PropertyGroup Condition="'$(UsingMicrosoftNETSdk)' == 'true'">
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Platforms>x64</Platforms>
    <Version>3.7.2</Version>
    <AssemblyVersion>3.7.2.0</AssemblyVersion>
    <FileVersion>3.7.2.0</FileVersion>
    <InformationalVersion>3.7.2</InformationalVersion>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
    <TieredCompilation>true</TieredCompilation>
    <TieredPGO>true</TieredPGO>
    <!-- Prevent MSBuild Roslyn compiler server from holding file handles across builds.
         Critical for network drives (OneDrive) to avoid AssemblyInfoInputs.cache locking
         when multiple assemblies are built in rapid succession. -->
    <UseSharedCompilation>false</UseSharedCompilation>
    <!-- GenerateAssemblyInfo is enabled — version attributes (AssemblyVersion, FileVersion,
         InformationalVersion) are embedded via the auto-generated AssemblyInfo.
         UseSharedCompilation=false (above) prevents the Roslyn server from holding
         file handles on the .cache file, so the OneDrive lock issue is avoided. -->
    <!-- Suppress CA1416 globally — this is a Windows-only project. All projects
         target net10.0-windows and will never run on non-Windows platforms. -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition="'$(UsingMicrosoftNETSdk)' == 'true' and '$(IsTestProject)' == 'true'">
    <IsPackable>false</IsPackable>
    <DisableAppDomain>true</DisableAppDomain>
  </PropertyGroup>
</Project>
