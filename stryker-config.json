{
  "stryker-config": {
    "project": "RegiLattice.Core.csproj",
    "test-projects": [
      "tests/RegiLattice.Core.Tests/RegiLattice.Core.Tests.csproj"
    ],
    "mutation-level": "Standard",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 55
    },
    "reporters": [
      "html",
      "progress",
      "cleartext",
      "json"
    ],
    "output-path": ".tmp/stryker-output",
    "log": {
      "log-level": "info"
    },
    "ignore-mutations": [
      "string",
      "Linq"
    ],
    "mutate": [
      "src/RegiLattice.Core/TweakEngine.cs",
      "src/RegiLattice.Core/Models/TweakDef.cs",
      "src/RegiLattice.Core/Registry/RegistrySession.cs",
      "src/RegiLattice.Core/TweakValidator.cs",
      "src/RegiLattice.Core/DependencyResolver.cs",
      "src/RegiLattice.Core/SnapshotManager.cs",
      "src/RegiLattice.Core/Services/AppConfig.cs",
      "src/RegiLattice.Core/Services/Favorites.cs",
      "src/RegiLattice.Core/Services/Ratings.cs",
      "src/RegiLattice.Core/Services/TweakHistory.cs",
      "src/RegiLattice.Core/Services/ConfigExporter.cs",
      "src/RegiLattice.Core/Plugins/PackLoader.cs",
      "src/RegiLattice.Core/Plugins/PackManager.cs",
      "src/RegiLattice.Core/Plugins/PackSignatureVerifier.cs",
      "src/RegiLattice.Core/Plugins/PluginSandbox.cs"
    ],
    "since": {
      "enabled": false
    }
  }
}
