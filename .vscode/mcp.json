{
  "inputs": [
    {
      "type": "promptString",
      "id": "github-token",
      "description": "GitHub Personal Access Token for MCP server",
      "password": true
    }
  ],
  "servers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github-token}",
        "PATH": "${env:APPDATA}\\npm;${env:USERPROFILE}\\scoop\\shims;${env:USERPROFILE}\\scoop\\apps\\nvm\\current\\nodejs\\nodejs;${env:PROGRAMFILES}\\nodejs;${env:PATH}",
        "HTTP_PROXY": "${env:HTTP_PROXY}",
        "HTTPS_PROXY": "${env:HTTPS_PROXY}",
        "http_proxy": "${env:HTTP_PROXY}",
        "https_proxy": "${env:HTTPS_PROXY}",
        "NO_PROXY": "localhost,127.0.0.1,::1",
        "no_proxy": "localhost,127.0.0.1,::1",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0",
        "npm_config_strict_ssl": "false"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ],
      "env": {
        "PATH": "${env:APPDATA}\\npm;${env:USERPROFILE}\\scoop\\shims;${env:USERPROFILE}\\scoop\\apps\\nvm\\current\\nodejs\\nodejs;${env:PROGRAMFILES}\\nodejs;${env:PATH}",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0",
        "npm_config_strict_ssl": "false"
      }
    },
    "project-docs": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}\\.github",
        "${workspaceFolder}\\docs"
      ],
      "env": {
        "PATH": "${env:APPDATA}\\npm;${env:USERPROFILE}\\scoop\\shims;${env:USERPROFILE}\\scoop\\apps\\nvm\\current\\nodejs\\nodejs;${env:PROGRAMFILES}\\nodejs;${env:PATH}",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0",
        "npm_config_strict_ssl": "false"
      }
    }
  }
}
