{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RegiLattice: GUI (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: Solution (Debug)",
      "program": "${workspaceFolder}/src/RegiLattice.GUI/bin/Debug/net10.0-windows/RegiLattice.GUI.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "RegiLattice: GUI (Release)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: Solution (Release)",
      "program": "${workspaceFolder}/src/RegiLattice.GUI/bin/Release/net10.0-windows/RegiLattice.GUI.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "RegiLattice: CLI (list)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: Solution (Debug)",
      "program": "${workspaceFolder}/src/RegiLattice.CLI/bin/Debug/net10.0-windows/RegiLattice.dll",
      "args": ["list"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "RegiLattice: CLI (apply tweak)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: Solution (Debug)",
      "program": "${workspaceFolder}/src/RegiLattice.CLI/bin/Debug/net10.0-windows/RegiLattice.dll",
      "args": ["apply", "${input:tweakId}", "--yes"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Tests: Debug All",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: Solution (Debug)",
      "program": "dotnet",
      "args": ["test", "RegiLattice.sln", "--no-build"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "inputs": [
    {
      "id": "tweakId",
      "type": "promptString",
      "description": "Tweak ID to apply (e.g. priv-disable-telemetry, ai-disable-copilot)"
    }
  ]
}
