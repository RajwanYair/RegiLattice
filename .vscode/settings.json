{
  // ── C# / .NET ───────────────────────────────────────────────────────
  "dotnet.defaultSolution": "RegiLattice.sln",
  "[csharp]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
    "editor.formatOnSave": true
  },
  // ── Python (disable venv auto-activation — this is a .NET project) ──
  "python.terminal.activateEnvironment": false,
  // ── PowerShell ──────────────────────────────────────────────────────
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.scriptAnalysis.enable": true,
  // ── Editor defaults ─────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [
    150
  ],
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.minimap.enabled": false,
  "editor.wordWrap": "off",
  "editor.stickyScroll.enabled": true,
  // ── Files ───────────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/archive": true,
    "**/.tmp": true,
    "**/publish": true,
    "installer/bin": true,
    "installer/obj": true
  },
  "files.watcherExclude": {
    "**/bin/**": true,
    "**/obj/**": true,
    "**/.tmp/**": true,
    "**/publish/**": true,
    "installer/bin/**": true,
    "installer/obj/**": true
  },
  // ── Search ──────────────────────────────────────────────────────────
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/archive": true,
    "**/.tmp": true,
    "**/publish": true,
    "installer/bin": true,
    "installer/obj": true
  },
  // ── Terminal (workspace entrypoint into shared MyScripts tooling) ─────
  "terminal.integrated.defaultProfile.windows": "RegiLattice Dev",
  "terminal.integrated.profiles.windows": {
    "RegiLattice Dev": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-Command",
        "& '${workspaceFolder}\\..\\.vscode\\scripts\\Initialize-CommonTooling.ps1' -WorkspaceRoot '${workspaceFolder}' -WorkspaceBootstrap '${workspaceFolder}\\.env.ps1'"
      ],
      "icon": "terminal-powershell"
    },
    "PowerShell": {
      "source": "PowerShell"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.shellIntegration.decorationsEnabled": "both",
  "terminal.integrated.shellIntegration.history": 500,
  "terminal.integrated.shellIntegration.suggestEnabled": false,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.suggest.quickSuggestions": true,
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.terminal.focusFind",
    "workbench.action.togglePanel"
  ],
  "terminal.integrated.enableImages": true,
  // Ensure Copilot chat agent terminals also see dotnet tools
  "github.copilot.chat.terminalChatLocation": "terminal",
  // ── Git ─────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  // ── Markdown ────────────────────────────────────────────────────────
  // Config lives in .markdownlint.json (project root) — takes precedence.
  // ── Network / proxy ────────────────────────────────────────────────
  "http.proxySupport": "on",
  "http.proxyStrictSSL": false,
  // ── YAML (redhat.vscode-yaml) ───────────────────────────────────────
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
  },
  "github-actions.workflows.pinned.enabled": false,
  "github-actions.workflows.pinned.refresh.enabled": false,
  // ── GitHub Copilot ──────────────────────────────────────────────────
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": ".github/copilot-instructions.md"
    },
    {
      "file": ".github/instructions/workspace.instructions.md"
    },
    {
      "file": ".github/instructions/csharp.instructions.md"
    },
    {
      "file": ".github/instructions/testing.instructions.md"
    },
    {
      "file": ".github/instructions/git-workflow.instructions.md"
    },
    {
      "file": ".github/instructions/lessons-learned.instructions.md"
    },
    {
      "file": ".github/instructions/cicd.instructions.md"
    },
    {
      "file": ".github/instructions/no-duplication.instructions.md"
    }
  ],
  "chat.promptFiles": true,
  "chat.agent.enabled": true,
  "github.copilot.chat.agent.terminal.allowList": {
    "Remove-Item": true,
    "dotnet": true,
    "git": true,
    "pwsh": true
  },
  // Agent request budget — allow complex multi-file/multi-tool agent sessions
  "chat.agent.maxRequests": 80,
  // Copilot next-edit suggestions (inline code suggestions while editing)
  "github.copilot.nextEditSuggestions.enabled": true,
  // ── VS Code 1.99+ MCP & agent mode settings ─────────────────────────────
  // Auto-start MCP servers when mcp.json changes (no manual restart needed)
  "chat.mcp.autoStart": true,
  // Auto-discover MCP configs from Claude Desktop and other MCP-aware apps
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  // Tool-based edit mode: model calls tools to make file edits (same engine as agent mode).
  // Enables seamless mode-switching mid-conversation. Requires a tool-calling model.
  "chat.edits2.enabled": true,
  // Thinking tool: gives the agent an explicit reasoning step between tool calls.
  // Improves performance on complex tasks (debugging 7k-tweak chains, sprint planning).
  "github.copilot.chat.agent.thinkingTool": true,
  // Semantic text search results surfaced in chat via #searchResults tool
  "github.copilot.chat.search.semanticTextResults": true,
  // ── Testing ─────────────────────────────────────────────────────────
  "dotnet.unitTests.runSettingsPath": "tests/.runsettings"
}
