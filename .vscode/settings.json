{
  // ── C# / .NET ───────────────────────────────────────────────────────
  "dotnet.defaultSolution": "RegiLattice.sln",
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.formatOnSave": true
  },
  // ── PowerShell ──────────────────────────────────────────────────────
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.scriptAnalysis.enable": true,
  // ── Editor defaults ─────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [
    150
  ],
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.minimap.enabled": false,
  "editor.wordWrap": "off",
  "editor.stickyScroll.enabled": true,
  // ── Files ───────────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/archive": true
  },
  // ── Search ──────────────────────────────────────────────────────────
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/archive": true
  },
  // ── Terminal (best shell integration) ────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "RegiLattice Dev",
  "terminal.integrated.profiles.windows": {
    "RegiLattice Dev": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", ". '${workspaceFolder}\\.env.ps1'"],
      "icon": "terminal-powershell"
    },
    "PowerShell": {
      "source": "PowerShell"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.enablePersistentSessions": true,
  // Ensure Copilot chat agent terminals also see dotnet tools
  "github.copilot.chat.terminalChatLocation": "terminal",
  // ── Git ─────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  // ── Markdown ────────────────────────────────────────────────────────
  // Config lives in .markdownlint.json (project root) — takes precedence.
  // ── YAML (redhat.vscode-yaml) ───────────────────────────────────────
  "http.proxySupport": "on",
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
  },
  "github-actions.workflows.pinned.enabled": false,
  "github-actions.workflows.pinned.refresh.enabled": false,
  // ── GitHub Copilot ──────────────────────────────────────────────────
  "github.copilot.chat.codeGeneration.instructions": [
    { "file": ".github/copilot-instructions.md" },
    { "file": ".github/instructions/workspace.instructions.md" },
    { "file": ".github/instructions/csharp.instructions.md" },
    { "file": ".github/instructions/testing.instructions.md" },
    { "file": ".github/instructions/git-workflow.instructions.md" },
    { "file": ".github/instructions/lessons-learned.instructions.md" },
    { "file": ".github/instructions/cicd.instructions.md" }
  ],
  "chat.promptFiles": true,
  "chat.agent.enabled": true
}
