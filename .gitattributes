# Git Attributes for ExplorerLens.io

# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cpp text eol=crlf
*.h text eol=crlf
*.c text eol=crlf
*.hpp text eol=crlf
*.cs text eol=crlf
*.csx text eol=crlf

# Scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh text eol=lf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=crlf
*.config text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Visual Studio files
*.sln text eol=crlf
*.csproj text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=crlf
*.rtf text eol=crlf

# Binary files
*.dll binary
*.exe binary
*.lib binary
*.obj binary
*.pdb binary
*.ilk binary
*.exp binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.rar binary
*.gz binary
