# Git Attributes for RegiLattice (C# / .NET project)

# Normalize all text files to LF in the repo; override specific tools that need CRLF
* text=auto eol=lf

# C# / .NET
*.cs      text eol=lf diff=csharp
*.csx     text eol=lf diff=csharp
*.csproj  text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.xaml    text eol=lf
*.resx    text eol=lf
*.config  text eol=lf
*.manifest text eol=lf
*.wixproj text eol=lf
*.wxs     text eol=lf
# Visual Studio solution files require CRLF
*.sln     text eol=crlf

# Shell / Scripts
*.ps1     text eol=crlf
*.psm1    text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.sh      text eol=lf

# Config / Data
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.cfg     text eol=lf
*.ini     text eol=lf

# Documentation
*.md      text eol=lf diff=markdown
*.txt     text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snk binary

# Legacy (archived Python)
*.py  text eol=lf linguist-vendored
*.pyi text eol=lf linguist-vendored