# Git Attributes for RegiLattice (Python project)

# Auto-detect text files and normalise to LF in the repo
* text=auto

# ── Python ───────────────────────────────────────────────────
*.py text eol=lf
*.pyi text eol=lf

# ── Shell / Scripts ──────────────────────────────────────────
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.psm1 text eol=crlf

# ── Config / Data ────────────────────────────────────────────
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# ── Documentation ────────────────────────────────────────────
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# ── Binary ───────────────────────────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.whl binary
