# Git Attributes for RegiLattice (C# / .NET project)

# Auto-detect text files and normalise line endings in the repo
* text=auto

# ── C# / .NET ────────────────────────────────────────────────
*.cs text diff=csharp
*.csx text diff=csharp
*.csproj text
*.sln text eol=crlf
*.props text
*.targets text
*.xaml text
*.resx text
*.config text
*.manifest text
*.wixproj text
*.wxs text

# ── Shell / Scripts ──────────────────────────────────────────
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh text eol=lf

# ── Config / Data ────────────────────────────────────────────
*.json text
*.yml text
*.yaml text
*.toml text
*.cfg text
*.ini text

# ── Documentation ────────────────────────────────────────────
*.md text diff=markdown
*.txt text

# ── Binary ───────────────────────────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snk binary

# ── Legacy (archived Python) ─────────────────────────────────
*.py text eol=lf linguist-vendored
*.pyi text eol=lf linguist-vendored
